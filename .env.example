# Slack — create app at https://api.slack.com/apps
# Enable Socket Mode, add app-level token with connections:write scope
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# GitHub — fine-grained PAT scoped to your target repo (Issues: Read/Write)
# Also needs Account permission: GitHub Copilot (Read) to use GitHub Models for AI
GITHUB_TOKEN=github_pat_...
# Optional: separate token just for GitHub Models AI, if your GITHUB_TOKEN lacks Copilot scope
GITHUB_MODELS_TOKEN=
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo

# Optional: default assignee GitHub username (leave blank to skip)
GITHUB_DEFAULT_ASSIGNEE=

# Optional: default label(s), comma-separated (e.g. "bug,needs-triage")
GITHUB_DEFAULT_LABELS=

# Set to "false" to skip AI enhancement entirely (issues filed verbatim)
AI_ENHANCE=true
